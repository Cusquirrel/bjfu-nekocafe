{
  "title": "NekoCafe Lab3 Overview",
  "schemaVersion": 39,
  "panels": [
    {
      "type": "stat",
      "title": "HTTP Requests",
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count[1m]))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "P95 Latency",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket[5m])) by (le))"
        }
      ]
    },
    {
      "type": "stat",
      "title": "JVM Memory Used",
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes)"
        }
      ]
    }
  ]
}